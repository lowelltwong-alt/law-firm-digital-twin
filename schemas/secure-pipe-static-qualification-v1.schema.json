{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:lfdt:schema:secure-pipe-static-qualification:v1",
  "title": "Secure Pipe Static Qualification v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["qualification_id", "revision", "pipe_name_commitment", "kernel_principal_commitment", "worker_principal_commitment", "open_mode", "pipe_mode", "max_instances", "buffer_bytes", "worker_access_mask", "first_instance_required", "remote_clients_rejected", "message_mode_required", "client_token_impersonation_required", "exact_sid_match_required", "revert_to_self_required", "default_security_descriptor_denied", "raw_sid_disclosed", "pipe_name_disclosed", "live_pipe_created", "live_os_qualified", "physical_isolation_qualified", "canonical_activation_authorized", "external_effects", "portable_class"],
  "properties": {
    "qualification_id": {"type": "string", "pattern": "^SPQ-[0-9a-f]{24}$"},
    "revision": {"const": "windows-secure-pipe-adapter-g0-v1"},
    "pipe_name_commitment": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "kernel_principal_commitment": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "worker_principal_commitment": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "open_mode": {"const": 524291},
    "pipe_mode": {"const": 14},
    "max_instances": {"const": 1},
    "buffer_bytes": {"const": 65540},
    "worker_access_mask": {"const": 1180035},
    "first_instance_required": {"const": true},
    "remote_clients_rejected": {"const": true},
    "message_mode_required": {"const": true},
    "client_token_impersonation_required": {"const": true},
    "exact_sid_match_required": {"const": true},
    "revert_to_self_required": {"const": true},
    "default_security_descriptor_denied": {"const": true},
    "raw_sid_disclosed": {"const": false},
    "pipe_name_disclosed": {"const": false},
    "live_pipe_created": {"const": false},
    "live_os_qualified": {"const": false},
    "physical_isolation_qualified": {"const": false},
    "canonical_activation_authorized": {"const": false},
    "external_effects": {"const": false},
    "portable_class": {"const": "runtime_adapter"}
  }
}
