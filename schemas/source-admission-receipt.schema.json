{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://law-firm-digital-twin.local/schemas/source-admission-receipt.schema.json",
  "title": "Law Firm Digital Twin source-admission receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id", "source_name", "issuing_authority", "retrieved_at",
    "effective_from", "effective_to", "license_posture", "intended_use",
    "prohibited_uses", "source_ref", "source_hash", "normalization_method",
    "validator", "owner", "review_status", "re_review_triggers"
  ],
  "properties": {
    "receipt_id": {"type": "string", "pattern": "^SAR-"},
    "source_name": {"type": "string", "minLength": 1},
    "issuing_authority": {"type": "string", "minLength": 1},
    "retrieved_at": {"type": "string", "format": "date-time"},
    "effective_from": {"type": ["string", "null"], "format": "date"},
    "effective_to": {"type": ["string", "null"], "format": "date"},
    "license_posture": {"type": "string", "enum": ["admitted", "restricted", "prohibited", "unknown_hold"]},
    "intended_use": {"type": "string", "minLength": 1},
    "prohibited_uses": {"type": "array", "items": {"type": "string"}},
    "source_ref": {"type": "string", "minLength": 1},
    "source_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "normalization_method": {"type": "string", "minLength": 1},
    "validator": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "review_status": {"type": "string", "enum": ["candidate", "approved", "rejected", "expired"]},
    "re_review_triggers": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
